{
  "name": "cursor-usage-viz",
  "version": "0.1.0",
  "private": true,
  "description": "A Bloomberg Terminal-style data visualization for Cursor usage events. Drop in a usage-events-*.csv exported from cursor.com/dashboard/usage and explore your model usage, costs, hottest requests, and 60-day heatmap — all locally in the browser.",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "playground": "pnpm --filter @cu/playground dev",
    "desktop:dev": "pnpm --filter @cu/desktop dev",
    "desktop:build": "pnpm --filter @cu/desktop build",
    "desktop:package": "pnpm --filter @cu/desktop package",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "playwright": "^1.60.0",
    "turbo": "2.3.3",
    "typescript": "5.6.3"
  }
}
