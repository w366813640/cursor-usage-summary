{
  "name": "@cu/desktop",
  "productName": "Cursor Usage",
  "description": "Cursor Usage — desktop dashboard for your Cursor IDE usage history, packaged as an Electron shell over the playground renderer.",
  "author": {
    "name": "cursor-usage-viz authors",
    "email": "noreply@example.com"
  },
  "license": "MIT",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/main/main.js",
  "scripts": {
    "dev": "tsx scripts/dev.mts",
    "build:main": "tsx scripts/build-main.mts",
    "build:renderer": "pnpm --filter @cu/playground build",
    "build": "pnpm build:main && pnpm build:renderer",
    "install-natives": "tsx scripts/install-natives.mts --runtime=electron",
    "install-natives:node": "tsx scripts/install-natives.mts --runtime=node",
    "rebuild-natives": "electron-rebuild -w better-sqlite3 -f",
    "package": "tsx scripts/package.mts",
    "package:dir": "tsx scripts/package.mts --dir",
    "package:win": "tsx scripts/package.mts --win",
    "typecheck": "tsc --noEmit -p tsconfig.main.json"
  },
  "dependencies": {
    "@cu/storage": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@cu/playground": "workspace:*",
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "electron": "^40.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "5.6.3"
  }
}
