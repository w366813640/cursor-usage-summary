enable-pre-post-scripts=true
shamefully-hoist=false
strict-peer-dependencies=false
auto-install-peers=true
node-linker=isolated

# Electron downloads its ~150MB Chromium binary via npm's postinstall;
# the default github.com mirror is unreliable from CN networks, so we
# route through npmmirror's electron mirror. Override at install time
# with: pnpm install --electron_mirror=https://github.com/electron/electron/releases/download/
electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/
